# ============================================================================
# STORYFORCE.AI ENVIRONMENT CONFIGURATION
# ============================================================================

# SERVER
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:3000

# DATABASE - PostgreSQL
DATABASE_URL=postgresql://storyforce_user:password@localhost:5432/storyforce_production
DB_HOST=localhost
DB_PORT=5432
DB_NAME=storyforce_production
DB_USER=storyforce_user
DB_PASSWORD=your-secure-password

# CACHE - Redis
REDIS_URL=redis://localhost:6379

# AWS - S3 Audio Storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=storyforce-audio-your-account-id

# API KEYS
JWT_SECRET=your-jwt-secret-key-change-this
JWT_EXPIRATION=7d

# FABLE LLM (Claude Fable)
FABLE_API_KEY=your-fable-api-key
FABLE_MODEL=claude-fable-5

# LLM COST TRACKING
LLM_BUDGET_LIMIT=1500

# GOOGLE GEMINI VOICE API
GOOGLE_API_KEY=your-google-api-key
GEMINI_VOICE_ENDPOINT=https://generativelanguage.googleapis.com/v1

# LOGGING
LOG_LEVEL=info
LOG_FORMAT=json

# FEATURE FLAGS
ENABLE_VOICE_COACHING=true
ENABLE_ANALYTICS=true
ENABLE_STORY_EXPORT=true

# SUBSCRIPTION SETTINGS
FREE_TIER_MONTHLY_LIMIT=5
PROFESSIONAL_TIER_PRICE=12.99
TEAM_TIER_PRICE=99.00

# CORS
CORS_ORIGIN=http://localhost:3000

# EMAIL (for future notifications)
SENDGRID_API_KEY=your-sendgrid-key
EMAIL_FROM=noreply@storyforce.ai

# SENTRY (Error tracking)
SENTRY_DSN=your-sentry-dsn

# DEVELOPMENT
DEBUG=storyforce:*
