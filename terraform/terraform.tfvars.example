aws_region  = "us-east-1"
environment = "production"
project_name = "storyforce"

# VPC Configuration
vpc_cidr              = "10.0.0.0/16"
public_subnet_cidrs   = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs  = ["10.0.10.0/24", "10.0.11.0/24"]

# Database Configuration
db_name          = "storyforce"
db_username      = "storyforce_admin"
db_password      = "your-secure-password-min-20-chars-required"
db_instance_class = "db.t4g.small"
db_instance_count = 2

# Redis Configuration
redis_cluster_id = "storyforce-cache"
redis_node_type  = "cache.t4g.micro"
redis_num_nodes  = 2
redis_auth_token = "your-secure-redis-token-min-32-chars-required"

# Additional Tags
additional_tags = {
  CostCenter = "Engineering"
  Owner      = "Scott Magnacca"
}
